				console.log("Subselection set to " + session.getItem("subselection")); 
				wixLocation.to("/shows/"+(session.getItem("subselection"))+ "/" + (session.getItem("year")));
			})
			$w('#MobileSemifinalsButton').onClick((event) => {
				session.setItem("subselection", "semi-finals");  
				console.log("Subselection set to " + session.getItem("subselection")); 
				wixLocation.to("/shows/"+(session.getItem("subselection"))+ "/" + (session.getItem("year")));
			})
			$w('#MobileSemifinalsButtonAlt').onClick((event) => {
				session.setItem("subselection", "semi-finals");  
				console.log("Subselection set to " + session.getItem("subselection")); 
				wixLocation.to("/shows/"+(session.getItem("subselection"))+ "/" + (session.getItem("year")));
			})
			$w('#MobileFinalsButton').onClick((event) => {
				session.setItem("subselection", "finals");  
				console.log("Subselection set to " + session.getItem("subselection")); 
				wixLocation.to("/shows/"+(session.getItem("subselection"))+ "/" + (session.getItem("year")));
			})
			$w('#MobileFinalsButtonAlt').onClick((event) => {
